{
  "name": "drop-sign",
  "version": "0.3.0",
  "description": "Drop signatures anywhere on the web.",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write src examples",
    "typecheck": "tsc --noEmit",
    "demo": "pnpm --filter @drop-sign/example dev"
  },
  "keywords": [
    "signature",
    "esignature",
    "sign",
    "canvas",
    "drag",
    "resize",
    "sdk",
    "overlay",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/muminjun/drop-sign.git"
  },
  "bugs": {
    "url": "https://github.com/muminjun/drop-sign/issues"
  },
  "homepage": "https://github.com/muminjun/drop-sign#readme",
  "dependencies": {
    "html-to-image": "^1.11.11",
    "interactjs": "^1.10.27",
    "signature_pad": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.15.3",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2",
    "happy-dom": "^17.5.4"
  }
}
